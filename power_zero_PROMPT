export interface NotificationProvider {
  send(title: string, body: string, data?: any): Promise<void>;
}

export const ProcessScheduledAlerts = async (
  subs: Subscription[], 
  provider: NotificationProvider
) => {
  const upcoming = GetExpiringSubscriptions(subs); // Our Core Logic
  
  for (const sub of upcoming) {
    await provider.send(
      "Upcoming Renewal", 
      `${sub.name} renews soon.`,
      { id: sub.id }
    );
  }
};
